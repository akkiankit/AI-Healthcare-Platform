  <diagram id="ok6Xza1YN6-M2J5rs0ts" name="7.Prescription Draft Assistance">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TB\n\nclassDef userLayer fill:#D6EAF8,stroke:#3498DB,stroke-width:2px,color:#000;\nclassDef backendLayer fill:#EBEDEF,stroke:#7B7D7D,stroke-width:2px,color:#000;\nclassDef frontendLayer fill:#E8DAEF,stroke:#AF7AC5,stroke-width:2px,color:#000;\nclassDef aiLayer fill:#FCF3CF,stroke:#D4AC0D,stroke-width:2px,color:#000;\nclassDef dataLayer fill:#D5F5E3,stroke:#27AE60,stroke-width:2px,color:#000;\nclassDef auditLayer fill:#FADBD8,stroke:#E74C3C,stroke-width:2px,color:#000;\nclassDef node fill:#F8F9F9,stroke:#909497,stroke-width:1px,color:#000;\nclassDef decision fill:#EBF5FB,stroke:#2E86C1,stroke-width:1.5px,color:#000;\nclassDef error fill:#FDEDEC,stroke:#E74C3C,stroke-width:1.5px,color:#000;\nclassDef success fill:#EAFBF1,stroke:#27AE60,stroke-width:1.5px,color:#000;\n\nTITLE[\&quot;Prescription Draft Assistance Workflow&lt;br/&gt;(Doctor-reviewed AI Prescription Draft)\&quot;]\n\nsubgraph USER[\&quot;👤 User Layer\&quot;]\ndirection TB\nU1[\&quot;Doctor opens&lt;br/&gt;Prescription Draft screen\&quot;]\nU2[\&quot;Doctor selects&lt;br/&gt;patient / consultation\&quot;]\nU3[\&quot;Doctor reviews / edits&lt;br/&gt;prescription\&quot;]\nU4{\&quot;Doctor approves&lt;br/&gt;prescription?\&quot;}\nend\n\nsubgraph FRONTEND[\&quot;🖥 Frontend / UI Layer\&quot;]\ndirection TB\nF1[\&quot;Frontend sends request&lt;br/&gt;Patient ID + Consultation ID\&quot;]\nF2[\&quot;Doctor enters or selects medicines&lt;br/&gt;Composition / Brand / Dosage / Duration\&quot;]\nF3[\&quot;Doctor clicks&lt;br/&gt;Generate AI Prescription Draft\&quot;]\nF4[\&quot;Display prescription draft&lt;br/&gt;to doctor\&quot;]\nF5[\&quot;Generate prescription output&lt;br/&gt;Printable / Downloadable / Shareable\&quot;]\nend\n\nsubgraph BACKEND[\&quot;⚙ Backend / API Layer\&quot;]\ndirection TB\nB1[\&quot;Backend API receives request\&quot;]\nB2[\&quot;Auth &amp; RBAC check&lt;br/&gt;Only doctor can create prescription draft\&quot;]\nB3{\&quot;Access granted?\&quot;}\nB4[\&quot;Fetch patient context&lt;br/&gt;Age • Gender • Allergies •&lt;br/&gt;Current Medications • History\&quot;]\nB5[\&quot;Fetch consultation notes&lt;br/&gt;Condition • Symptoms • Doctor observations\&quot;]\nB6[\&quot;Validate prescription context\&quot;]\nB7[\&quot;Save prescription as AI draft\&quot;]\nB8[\&quot;Save final approved prescription\&quot;]\nend\n\nsubgraph AI[\&quot;🤖 AI Layer\&quot;]\ndirection TB\nAI1[\&quot;Prescription Draft Service\&quot;]\nAI2[\&quot;Apply AI Safety Rules&lt;br/&gt;No auto-prescription&lt;br/&gt;Avoid over-prescribing&lt;br/&gt;Check allergies and context\&quot;]\nAI3[\&quot;Prepare controlled&lt;br/&gt;prompt template\&quot;]\nAI4[\&quot;Call LLM Provider\&quot;]\nAI5[\&quot;Receive structured prescription draft&lt;br/&gt;Medicine • Dosage • Duration •&lt;br/&gt;Instructions • Warnings\&quot;]\nAI6[\&quot;Validate AI output format\&quot;]\nAI7{\&quot;Valid response?\&quot;}\nend\n\nsubgraph DATA[\&quot;🗄 Data Layer\&quot;]\ndirection TB\nD1[\&quot;Patient clinical context\&quot;]\nD2[\&quot;Consultation record\&quot;]\nD3[\&quot;Prescription draft / final prescription\&quot;]\nD4[\&quot;Patient prescription history\&quot;]\nend\n\nsubgraph AUDIT[\&quot;🔒 Audit &amp; Security Layer\&quot;]\ndirection TB\nA1[\&quot;Return access denied\&quot;]\nA2[\&quot;Return generation failed&lt;br/&gt;Doctor can create manually\&quot;]\nA3[\&quot;Create audit log&lt;br/&gt;Prescription draft generated\&quot;]\nA4[\&quot;Create audit log&lt;br/&gt;Prescription approved / edited\&quot;]\nA5[\&quot;Keep as draft / discard\&quot;]\nend\n\nTITLE --&gt; U1 --&gt; U2 --&gt; F1 --&gt; B1 --&gt; B2 --&gt; B3\n\nB3 --&gt;|No| A1\nB3 --&gt;|Yes| B4 --&gt; B5 --&gt; B6\n\nD1 --&gt; B4\nD2 --&gt; B5\n\nB6 --&gt; F2 --&gt; F3 --&gt; AI1\nAI1 --&gt; AI2 --&gt; AI3 --&gt; AI4 --&gt; AI5 --&gt; AI6 --&gt; AI7\n\nAI7 --&gt;|No| A2\nAI7 --&gt;|Yes| B7 --&gt; D3 --&gt; A3 --&gt; F4 --&gt; U3 --&gt; U4\n\nU4 --&gt;|No| A5\nU4 --&gt;|Yes| B8 --&gt; D3 --&gt; A4 --&gt; F5 --&gt; D4\n\nclass USER userLayer;\nclass FRONTEND frontendLayer;\nclass BACKEND backendLayer;\nclass AI aiLayer;\nclass DATA dataLayer;\nclass AUDIT auditLayer;\n\nclass U1,U2,U3,F1,F2,F3,F4,F5,B1,B2,B4,B5,B6,B7,B8,AI1,AI2,AI3,AI4,AI5,AI6,D1,D2,D3,D4,A3,A4 node;\nclass B3,AI7,U4 decision;\nclass A1,A2,A5 error;\nclass D4 success;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="xTUuhgaKdDctAxHkj-PH-1">
