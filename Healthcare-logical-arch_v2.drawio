  <diagram id="G49IonU5XwEr6E0Se7Ey" name="6.Condition-based AI Assistance">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TB\n\nclassDef userLayer fill:#D6EAF8,stroke:#3498DB,stroke-width:2px,color:#000;\nclassDef backendLayer fill:#EBEDEF,stroke:#7B7D7D,stroke-width:2px,color:#000;\nclassDef frontendLayer fill:#E8DAEF,stroke:#AF7AC5,stroke-width:2px,color:#000;\nclassDef aiLayer fill:#FCF3CF,stroke:#D4AC0D,stroke-width:2px,color:#000;\nclassDef dataLayer fill:#D5F5E3,stroke:#27AE60,stroke-width:2px,color:#000;\nclassDef auditLayer fill:#FADBD8,stroke:#E74C3C,stroke-width:2px,color:#000;\nclassDef node fill:#F8F9F9,stroke:#909497,stroke-width:1px,color:#000;\nclassDef decision fill:#EBF5FB,stroke:#2E86C1,stroke-width:1.5px,color:#000;\nclassDef error fill:#FDEDEC,stroke:#E74C3C,stroke-width:1.5px,color:#000;\nclassDef success fill:#EAFBF1,stroke:#27AE60,stroke-width:1.5px,color:#000;\n\nTITLE[\&quot;Condition-based AI Assistance Workflow&lt;br/&gt;(AI-Assisted Clinical Decision Support)\&quot;]\n\nsubgraph USER[\&quot;👤 User Layer\&quot;]\ndirection TB\nU1[\&quot;Doctor opens&lt;br/&gt;Condition-based Assistance\&quot;]\nend\n\nsubgraph BACKEND[\&quot;⚙ Backend / API Layer\&quot;]\ndirection TB\nB1[\&quot;Doctor enters confirmed / suspected condition&lt;br/&gt;(Example: Viral Fever, Hypertension)\&quot;]\nB2[\&quot;Backend API receives request\&quot;]\nB3[\&quot;Auth &amp; RBAC check&lt;br/&gt;(Only doctor can request condition assistance)\&quot;]\nD1{\&quot;Access granted?\&quot;}\nB4[\&quot;Fetch patient context&lt;br/&gt;(Age • Gender • Vitals • Allergies •&lt;br/&gt;Current Medications • History)\&quot;]\nB5[\&quot;Validate required context\&quot;]\nD2{\&quot;Context sufficient?\&quot;}\nend\n\nsubgraph AUDIT[\&quot;🔒 Audit &amp; Security Layer\&quot;]\ndirection TB\nA1[\&quot;Create audit log&lt;br/&gt;(Request + Response + Doctor Action)\&quot;]\nA2[\&quot;Audit log for&lt;br/&gt;AI assistance generated\&quot;]\nend\n\nsubgraph FRONTEND[\&quot;🖥 Frontend / UI Layer\&quot;]\ndirection LR\nF1[\&quot;Frontend sends request&lt;br/&gt;(Patient ID + Condition +&lt;br/&gt;Optional Intake Context)\&quot;]\nF2[\&quot;Display patient context&lt;br/&gt;for review\&quot;]\nF3[\&quot;Show AI Assistance&lt;br/&gt;results to doctor\&quot;]\nF4[\&quot;Display recommendations&lt;br/&gt;&amp; follow-up points\&quot;]\nF5[\&quot;Doctor reviews, accepts,&lt;br/&gt;edits or ignores suggestions\&quot;]\nend\n\nsubgraph AI[\&quot;🤖 AI Layer\&quot;]\ndirection TB\nAI1[\&quot;Apply AI Safety Rules&lt;br/&gt;(Doctor-initiated queries only,&lt;br/&gt;No autonomous prescription)\&quot;]\nAI2[\&quot;Prepare controlled&lt;br/&gt;prompt template\&quot;]\nAI3[\&quot;Call LLM Provider\&quot;]\nAI4[\&quot;Generate structured AI draft&lt;br/&gt;(Concise explanations • Treatment considerations •&lt;br/&gt;Monitoring • Follow-up points)\&quot;]\nAI5[\&quot;Validate AI output&lt;br/&gt;format &amp; safety\&quot;]\nD3{\&quot;Valid response?\&quot;}\nend\n\nsubgraph DATA[\&quot;🗄 Data Layer\&quot;]\ndirection LR\nDTA1[\&quot;Patient&lt;br/&gt;Demographics&lt;br/&gt;&amp; History\&quot;]\nDTA2[\&quot;Vitals &amp;&lt;br/&gt;Allergies\&quot;]\nDTA3[\&quot;Current&lt;br/&gt;Medications\&quot;]\nDTA4[\&quot;Past Consultations&lt;br/&gt;&amp; Prescriptions\&quot;]\nDTA5[\&quot;Clinical Notes&lt;br/&gt;&amp; Intake Data\&quot;]\nend\n\nsubgraph STORE[\&quot;🗄 Data Store\&quot;]\ndirection TB\nS1[\&quot;AI Assistance Records&lt;br/&gt;(Audit Log, Inputs,&lt;br/&gt;Outputs, Doctor Actions)\&quot;]\nend\n\nsubgraph LEGEND[\&quot;Legend\&quot;]\ndirection LR\nL1[\&quot;User Layer&lt;br/&gt;Doctor initiates request\&quot;]\nL2[\&quot;Backend Layer&lt;br/&gt;Request handling,&lt;br/&gt;auth &amp; data fetch\&quot;]\nL3[\&quot;Frontend Layer&lt;br/&gt;UI interaction&lt;br/&gt;&amp; display\&quot;]\nL4[\&quot;AI Layer&lt;br/&gt;AI processing&lt;br/&gt;&amp; validation\&quot;]\nL5[\&quot;Data Layer&lt;br/&gt;Clinical data&lt;br/&gt;sources\&quot;]\nL6[\&quot;Audit Layer&lt;br/&gt;Security &amp;&lt;br/&gt;audit trail\&quot;]\nend\n\nTITLE --&gt; U1\nU1 --&gt; B1\nB1 --&gt; F1\nF1 --&gt; B2\nB2 --&gt; B3\nB3 --&gt; D1\n\nD1 --&gt;|No| E1[\&quot;Access denied\&quot;]\nD1 --&gt;|Yes| B4\n\nB3 --&gt; A1\nA1 --&gt; A2\n\nB4 --&gt; B5\nB5 --&gt; D2\n\nD2 --&gt;|No| E2[\&quot;Return message&lt;br/&gt;Please enter required information\&quot;]\nD2 --&gt;|Yes| F2\n\nF2 --&gt; AI1\nDTA1 --&gt; AI1\nDTA2 --&gt; AI1\nDTA3 --&gt; AI1\nDTA4 --&gt; AI1\nDTA5 --&gt; AI1\n\nAI1 --&gt; AI2 --&gt; AI3 --&gt; AI4 --&gt; AI5 --&gt; D3\n\nD3 --&gt;|No| E3[\&quot;Return AI generation failed&lt;br/&gt;or retry safely\&quot;]\nD3 --&gt;|Yes| S1\n\nS1 --&gt; F3\nF3 --&gt; F4\nF4 --&gt; F5\n\nF5 --&gt; D4{\&quot;Doctor accepts&lt;br/&gt;any suggestions?\&quot;}\n\nD4 --&gt;|No| E4[\&quot;Mark draft as not used\&quot;]\nD4 --&gt;|Yes| F6[\&quot;Doctor selects / edits&lt;br/&gt;useful suggestions\&quot;]\n\nF6 --&gt; F7[\&quot;Add selected items to&lt;br/&gt;consultation notes or&lt;br/&gt;prescription preparation\&quot;]\nF7 --&gt; A3[\&quot;Create audit log&lt;br/&gt;Doctor reviewed / edited&lt;br/&gt;AI suggestions\&quot;]\nA3 --&gt; FINAL[\&quot;Final decision&lt;br/&gt;remains with doctor\&quot;]\n\nclass USER userLayer;\nclass BACKEND backendLayer;\nclass FRONTEND frontendLayer;\nclass AI aiLayer;\nclass DATA dataLayer;\nclass AUDIT auditLayer;\nclass STORE dataLayer;\nclass LEGEND node;\nclass U1,B1,B2,B3,B4,B5,F1,F2,F3,F4,F5,F6,F7,AI1,AI2,AI3,AI4,AI5,DTA1,DTA2,DTA3,DTA4,DTA5,S1,A1,A2,A3,L1,L2,L3,L4,L5,L6 node;\nclass D1,D2,D3,D4 decision;\nclass E1,E2,E3,E4 error;\nclass FINAL success;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="yy-h4GDSVNWtCWFIeYqc-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
