        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TB\n\nclassDef userLayer fill:#D6EAF8,stroke:#3498DB,stroke-width:2px,color:#000;\nclassDef backendLayer fill:#EBEDEF,stroke:#7B7D7D,stroke-width:2px,color:#000;\nclassDef frontendLayer fill:#E8DAEF,stroke:#AF7AC5,stroke-width:2px,color:#000;\nclassDef aiLayer fill:#FCF3CF,stroke:#D4AC0D,stroke-width:2px,color:#000;\nclassDef dataLayer fill:#D5F5E3,stroke:#27AE60,stroke-width:2px,color:#000;\nclassDef auditLayer fill:#FADBD8,stroke:#E74C3C,stroke-width:2px,color:#000;\nclassDef node fill:#F8F9F9,stroke:#909497,color:#000;\nclassDef decision fill:#EBF5FB,stroke:#2E86C1,color:#000;\nclassDef error fill:#FDEDEC,stroke:#E74C3C,color:#000;\nclassDef success fill:#EAFBF1,stroke:#27AE60,color:#000;\n\nTITLE[\&quot;Diagnostic Report Simplification Workflow\&quot;]\n\nsubgraph USER[\&quot;👤 User Layer\&quot;]\ndirection TB\nU1[\&quot;Doctor opens Diagnostic Report screen\&quot;]\nU2[\&quot;Doctor selects patient / consultation\&quot;]\nU3[\&quot;Doctor reviews / edits explanation\&quot;]\nU4{\&quot;Doctor approves explanation?\&quot;}\nend\n\nsubgraph FRONTEND[\&quot;🖥 Frontend / UI Layer\&quot;]\ndirection TB\nF1[\&quot;Upload or scan diagnostic report&lt;br/&gt;PDF / Image\&quot;]\nF2[\&quot;Frontend validates file&lt;br/&gt;Type • Size\&quot;]\nF3[\&quot;Ask doctor to review / correct&lt;br/&gt;extracted values\&quot;]\nF4[\&quot;Display simplified explanation&lt;br/&gt;to doctor\&quot;]\nend\n\nsubgraph BACKEND[\&quot;⚙ Backend / API Layer\&quot;]\ndirection TB\nB1[\&quot;Backend API receives report upload\&quot;]\nB2[\&quot;Auth &amp; RBAC validation\&quot;]\nD1{\&quot;Access granted?\&quot;}\nB3[\&quot;Store original report&lt;br/&gt;in file storage\&quot;]\nB4[\&quot;Validate extracted data\&quot;]\nD2{\&quot;Extraction quality acceptable?\&quot;}\nB5[\&quot;Save report explanation&lt;br/&gt;as AI draft\&quot;]\nB6[\&quot;Save doctor-approved explanation\&quot;]\nend\n\nsubgraph OCR[\&quot;📄 Document Processing Layer\&quot;]\ndirection TB\nO1[\&quot;Send report to OCR / Document Intelligence\&quot;]\nO2[\&quot;Extract report text, tables, values&lt;br/&gt;CBC • Sugar • Thyroid • Lipid • LFT • KFT\&quot;]\nend\n\nsubgraph AI[\&quot;🤖 AI Layer\&quot;]\ndirection TB\nAI1[\&quot;Report Simplification AI Service\&quot;]\nAI2[\&quot;Apply AI Safety Rules&lt;br/&gt;No confirmed diagnosis&lt;br/&gt;Informational explanation only&lt;br/&gt;Doctor supervision required\&quot;]\nAI3[\&quot;Prepare prompt template&lt;br/&gt;Simplify abnormal values and concerns\&quot;]\nAI4[\&quot;Call LLM Provider\&quot;]\nAI5[\&quot;Receive structured AI draft&lt;br/&gt;Simple explanation • Abnormal values •&lt;br/&gt;Possible concerns • Follow-up considerations\&quot;]\nAI6[\&quot;Validate AI output format\&quot;]\nD3{\&quot;Valid response?\&quot;}\nend\n\nsubgraph DATA[\&quot;🗄 Data Layer\&quot;]\ndirection TB\nDT1[\&quot;Diagnostic report file\&quot;]\nDT2[\&quot;Extracted report values\&quot;]\nDT3[\&quot;AI explanation draft / approved explanation\&quot;]\nDT4[\&quot;Patient record &amp; consultation history\&quot;]\nend\n\nsubgraph AUDIT[\&quot;🔒 Audit &amp; Security Layer\&quot;]\ndirection TB\nA1[\&quot;Return access denied\&quot;]\nA2[\&quot;Return simplification failed&lt;br/&gt;Doctor can review manually\&quot;]\nA3[\&quot;Keep as draft / discard\&quot;]\nA4[\&quot;Create audit log&lt;br/&gt;Report uploaded and simplified\&quot;]\nA5[\&quot;Create audit log&lt;br/&gt;Report explanation approved / edited\&quot;]\nend\n\nTITLE --&gt; U1 --&gt; U2 --&gt; F1 --&gt; F2 --&gt; B1 --&gt; B2 --&gt; D1\n\nD1 --&gt;|No| A1\nD1 --&gt;|Yes| B3\n\nB3 --&gt; DT1\nB3 --&gt; O1 --&gt; O2 --&gt; DT2 --&gt; B4 --&gt; D2\n\nD2 --&gt;|No| F3\nF3 --&gt; AI1\nD2 --&gt;|Yes| AI1\n\nAI1 --&gt; AI2 --&gt; AI3 --&gt; AI4 --&gt; AI5 --&gt; AI6 --&gt; D3\n\nD3 --&gt;|No| A2\nD3 --&gt;|Yes| B5 --&gt; DT3 --&gt; A4 --&gt; F4 --&gt; U3 --&gt; U4\n\nU4 --&gt;|No| A3\nU4 --&gt;|Yes| B6 --&gt; DT3 --&gt; A5 --&gt; DT4\n\nclass USER userLayer;\nclass FRONTEND frontendLayer;\nclass BACKEND backendLayer;\nclass OCR aiLayer;\nclass AI aiLayer;\nclass DATA dataLayer;\nclass AUDIT auditLayer;\n\nclass U1,U2,U3,F1,F2,F3,F4,B1,B2,B3,B4,B5,B6,O1,O2,AI1,AI2,AI3,AI4,AI5,AI6,DT1,DT2,DT3,DT4,A4,A5 node;\nclass D1,D2,D3,U4 decision;\nclass A1,A2,A3 error;\nclass DT4 success;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="ySejEo4jEsLJ4drdMPVx-1">
