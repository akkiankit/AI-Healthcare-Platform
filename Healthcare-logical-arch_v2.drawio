    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TB\n\nclassDef userLayer fill:#D6EAF8,stroke:#3498DB,stroke-width:2px,color:#000;\nclassDef backendLayer fill:#EBEDEF,stroke:#7B7D7D,stroke-width:2px,color:#000;\nclassDef frontendLayer fill:#E8DAEF,stroke:#AF7AC5,stroke-width:2px,color:#000;\nclassDef aiLayer fill:#FCF3CF,stroke:#D4AC0D,stroke-width:2px,color:#000;\nclassDef dataLayer fill:#D5F5E3,stroke:#27AE60,stroke-width:2px,color:#000;\nclassDef auditLayer fill:#FADBD8,stroke:#E74C3C,stroke-width:2px,color:#000;\nclassDef node fill:#F8F9F9,stroke:#909497,color:#000;\nclassDef decision fill:#EBF5FB,stroke:#2E86C1,color:#000;\nclassDef error fill:#FDEDEC,stroke:#E74C3C,color:#000;\nclassDef success fill:#EAFBF1,stroke:#27AE60,color:#000;\n\nTITLE[\&quot;Medicine Composition → Brand Mapping Workflow\&quot;]\n\nsubgraph USER[\&quot;👤 User Layer\&quot;]\ndirection TB\nU1[\&quot;Doctor opens Medicine Search / Mapping\&quot;]\nU2[\&quot;Doctor enters medicine composition&lt;br/&gt;Example: Paracetamol + Aceclofenac\&quot;]\nU3[\&quot;Doctor selects preferred brand\&quot;]\nend\n\nsubgraph FRONTEND[\&quot;🖥 Frontend / UI Layer\&quot;]\ndirection TB\nF1[\&quot;Frontend sends composition search request\&quot;]\nF2[\&quot;Display matching medicine brands\&quot;]\nF3[\&quot;Show allergy / interaction warning\&quot;]\nend\n\nsubgraph BACKEND[\&quot;⚙ Backend / API Layer\&quot;]\ndirection TB\nB1[\&quot;Backend API receives request\&quot;]\nB2[\&quot;Auth &amp; RBAC validation\&quot;]\nD1{\&quot;Access granted?\&quot;}\n\nB3[\&quot;Normalize composition&lt;br/&gt;Spelling • Generic names • Dosage form\&quot;]\n\nB4[\&quot;Search medicine repository\&quot;]\n\nD2{\&quot;Matching brands found?\&quot;}\n\nB5[\&quot;Validate patient context&lt;br/&gt;Age • Allergies • Current medications\&quot;]\n\nB6[\&quot;Save selected medicine&lt;br/&gt;to prescription draft\&quot;]\nend\n\nsubgraph DATA[\&quot;🗄 Data Layer\&quot;]\ndirection TB\nDT1[\&quot;Medicine Master Database\&quot;]\nDT2[\&quot;Prescription Draft\&quot;]\nend\n\nsubgraph AUDIT[\&quot;🔒 Audit &amp; Security Layer\&quot;]\ndirection TB\nA1[\&quot;Return access denied\&quot;]\nA2[\&quot;No matching brand found&lt;br/&gt;Suggest refine search\&quot;]\nA3[\&quot;Create audit log&lt;br/&gt;Medicine searched / selected\&quot;]\nend\n\nTITLE --&gt; U1 --&gt; U2 --&gt; F1 --&gt; B1 --&gt; B2 --&gt; D1\n\nD1 --&gt;|No| A1\nD1 --&gt;|Yes| B3\n\nDT1 --&gt; B4\n\nB3 --&gt; B4 --&gt; D2\n\nD2 --&gt;|No| A2\nD2 --&gt;|Yes| F2\n\nF2 --&gt; U3 --&gt; B5\n\nB5 --&gt; F3\n\nF3 --&gt; B6\n\nB6 --&gt; DT2\nDT2 --&gt; A3\n\nclass USER userLayer;\nclass FRONTEND frontendLayer;\nclass BACKEND backendLayer;\nclass DATA dataLayer;\nclass AUDIT auditLayer;\n\nclass U1,U2,U3,F1,F2,F3,B1,B2,B3,B4,B5,B6,DT1,DT2,A3 node;\nclass D1,D2 decision;\nclass A1,A2 error;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="hdjdoUIuMHIgRSq40ztl-1">
